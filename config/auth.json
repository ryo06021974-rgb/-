{
  "auth": {
    "enabled": true,
    "required_before_result": true,
    "method": "profile_form",
    "fields": [
      {
        "id": "name",
        "label": "氏名",
        "type": "text",
        "required": true
      },
      {
        "id": "email",
        "label": "メールアドレス",
        "type": "email",
        "required": true
      },
      {
        "id": "company",
        "label": "会社名",
        "type": "text",
        "required": false
      },
      {
        "id": "department",
        "label": "部署",
        "type": "text",
        "required": false
      },
      {
        "id": "job_type",
        "label": "職種",
        "type": "text",
        "required": false
      },
      {
        "id": "position",
        "label": "役職",
        "type": "text",
        "required": false
      }
    ],
    "consent": {
      "enabled": true,
      "required": true,
      "label": "入力した個人情報と診断結果が管理者に共有・保存されることに同意します"
    }
  }
}
